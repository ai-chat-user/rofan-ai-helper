{
  "manifest_version": 3,
  "name": "Rofan AI Helper",
  "description": "Rofan AI 전용 백업, 메모, 평점, 숨김, 테마, 통계 도우미",
  "version": "0.24.4",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": [
    "storage",
    "clipboardWrite",
    "unlimitedStorage",
    "downloads"
  ],
  "host_permissions": [
    "https://rofan.ai/*",
    "https://www.rofan.ai/*",
    "https://api.novelai.net/*",
    "https://image.novelai.net/*",
    "https://generativelanguage.googleapis.com/*",
    "https://api.deepseek.com/*",
    "https://api.openai.com/*",
    "https://api.x.ai/*",
    "https://api.anthropic.com/*",
    "https://open.er-api.com/*"
  ],
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://rofan.ai/*",
        "https://www.rofan.ai/*"
      ],
      "js": [
        "src/page-hook.js"
      ],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://rofan.ai/*",
        "https://www.rofan.ai/*"
      ],
      "js": [
        "src/content.js"
      ],
      "css": [
        "src/styles.css"
      ],
      "run_at": "document_idle"
    }
  ]
}
